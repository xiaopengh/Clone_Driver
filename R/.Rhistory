sd_factor <- 0.94
ggplot(df, aes(x = ratio)) +
geom_histogram(aes(y = after_stat(density)), bins = 100, fill = "blue", alpha = 0.3, col = "gray31") +
stat_function(fun = dnorm,
args = list(mean = mean(df$ratio, na.rm = TRUE),
sd = sd_factor * sd(df$ratio, na.rm = TRUE)),
color = "navy",
linewidth = 1
)
ls(all.names = TRUE)
rm(df, sd_factor)
View(relpos)
View(pmutdt)
save.image()
View(gtf_dt)
